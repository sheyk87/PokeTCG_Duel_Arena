# ==============================================================================
# CONFIGURACIÓN DEL SERVIDOR POKÉMON TCG - PLANTILLA DE ENTORNO
# ==============================================================================

# Puerto interno del servidor Node (Debe coincidir con la configuración de nginx.conf)
PORT=3000

# Google Client ID para la autenticación de Google Sign-In
# Para obtener uno:
# 1. Ve a Google Cloud Console (https://console.cloud.google.com/)
# 2. Crea un proyecto y navega a "API y Servicios" > "Credenciales".
# 3. Haz clic en "Crear credenciales" > "ID de cliente OAuth".
# 4. Selecciona "Aplicación web" y añade "http://localhost:3000" como origen JavaScript autorizado.
# 5. Copia el ID de cliente generado y pégalo abajo:
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID_PLACEHOLDER

# ==============================================================================
# BASE DE DATOS EXTERNA (MySQL)
# ==============================================================================

# Dirección IP o nombre de host de tu base de datos MySQL.
# IMPORTANTE (Dado que MySQL está en otro contenedor de Docker en la red "templates_default"):
# - Usa "db" o "templates-db-1" para conectarse directamente por la red interna.
# - Si la DB estuviera en la máquina Host de Linux fuera de Docker, usarías 172.19.0.1 (Gateway).
DB_HOST=db

# Usuario de conexión de base de datos
DB_USER=root

# Contraseña de la base de datos
DB_PASSWORD=R00tMySQL

# Nombre de la base de datos (se creará automáticamente si no existe)
DB_NAME=pkmn_cards_db
